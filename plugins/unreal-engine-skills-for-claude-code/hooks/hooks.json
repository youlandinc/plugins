{
  "description": "Unreal Engine Skills for Claude Code hooks",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/unreal-context.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
