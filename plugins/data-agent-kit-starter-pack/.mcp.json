{
  "mcpServers": {
    "notebook": {
      "command": "npx",
      "args": [
        "-y",
        "git+https://github.com/gemini-cli-extensions/data-agent-kit-starter-pack.git",
        "--mode=notebook"
      ],
      "env": {},
      "env_vars": [
        "DATA_CLOUD_CURR_IDE_NAME"
      ]
    },
    "visualization": {
      "command": "npx",
      "args": [
        "-y",
        "git+https://github.com/gemini-cli-extensions/data-agent-kit-starter-pack.git",
        "--mode=visualization"
      ],
      "env": {},
      "env_vars": [
        "DATA_CLOUD_CURR_IDE_NAME"
      ]
    },
    "bigquery": {
      "command": "npx",
      "args": [
        "-y",
        "@toolbox-sdk/server@>=1.1.0",
        "--prebuilt",
        "bigquery",
        "--stdio",
        "--user-agent-metadata",
        "datacloud.codex"
      ],
      "env": {
        "BIGQUERY_LOCATION": "$BIGQUERY_LOCATION",
        "BIGQUERY_PROJECT": "$PROJECT_ID"
      }
    },
    "spanner": {
      "command": "npx",
      "args": [
        "-y",
        "@toolbox-sdk/server@>=1.1.0",
        "--prebuilt",
        "spanner",
        "--stdio",
        "--user-agent-metadata",
        "datacloud.codex"
      ],
      "env": {
        "SPANNER_DATABASE": "",
        "SPANNER_DIALECT": "",
        "SPANNER_INSTANCE": "",
        "SPANNER_PROJECT": "$PROJECT_ID"
      }
    },
    "alloydb-postgres-admin": {
      "command": "npx",
      "args": [
        "-y",
        "@toolbox-sdk/server@>=1.1.0",
        "--prebuilt",
        "alloydb-postgres-admin",
        "--stdio",
        "--user-agent-metadata",
        "datacloud.codex"
      ],
      "env": {}
    },
    "alloydb-postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@toolbox-sdk/server@>=1.1.0",
        "--prebuilt",
        "alloydb-postgres",
        "--stdio",
        "--user-agent-metadata",
        "datacloud.codex"
      ],
      "env": {
        "ALLOYDB_POSTGRES_CLUSTER": "",
        "ALLOYDB_POSTGRES_DATABASE": "",
        "ALLOYDB_POSTGRES_INSTANCE": "",
        "ALLOYDB_POSTGRES_IP_TYPE": "",
        "ALLOYDB_POSTGRES_PASSWORD": "",
        "ALLOYDB_POSTGRES_PROJECT": "$PROJECT_ID",
        "ALLOYDB_POSTGRES_REGION": "$GCP_REGION",
        "ALLOYDB_POSTGRES_USER": ""
      }
    },
    "cloud-sql-postgresql-admin": {
      "command": "npx",
      "args": [
        "-y",
        "@toolbox-sdk/server@>=1.1.0",
        "--prebuilt",
        "cloud-sql-postgres-admin",
        "--stdio",
        "--user-agent-metadata",
        "datacloud.codex"
      ],
      "env": {}
    },
    "cloud-sql-postgresql": {
      "command": "npx",
      "args": [
        "-y",
        "@toolbox-sdk/server@>=1.1.0",
        "--prebuilt",
        "cloud-sql-postgres",
        "--stdio",
        "--user-agent-metadata",
        "datacloud.codex"
      ],
      "env": {
        "CLOUD_SQL_POSTGRES_DATABASE": "",
        "CLOUD_SQL_POSTGRES_INSTANCE": "",
        "CLOUD_SQL_POSTGRES_IP_TYPE": "",
        "CLOUD_SQL_POSTGRES_PASSWORD": "",
        "CLOUD_SQL_POSTGRES_PROJECT": "$PROJECT_ID",
        "CLOUD_SQL_POSTGRES_REGION": "$GCP_REGION",
        "CLOUD_SQL_POSTGRES_USER": ""
      }
    },
    "knowledge_catalog": {
      "command": "npx",
      "args": [
        "-y",
        "@toolbox-sdk/server@>=1.1.0",
        "--prebuilt",
        "dataplex",
        "--stdio",
        "--user-agent-metadata",
        "datacloud.codex"
      ],
      "env": {
        "DATAPLEX_PROJECT": "$PROJECT_ID"
      }
    },
    "dataproc": {
      "command": "npx",
      "args": [
        "-y",
        "@toolbox-sdk/server@>=1.1.0",
        "--prebuilt",
        "dataproc",
        "--stdio",
        "--user-agent-metadata",
        "datacloud.codex"
      ],
      "env": {
        "DATAPROC_PROJECT": "$PROJECT_ID",
        "DATAPROC_REGION": "$GCP_REGION"
      }
    },
    "serverless-spark": {
      "command": "npx",
      "args": [
        "-y",
        "@toolbox-sdk/server@>=1.1.0",
        "--prebuilt",
        "serverless-spark",
        "--stdio",
        "--user-agent-metadata",
        "datacloud.codex"
      ],
      "env": {
        "SERVERLESS_SPARK_PROJECT": "$PROJECT_ID",
        "SERVERLESS_SPARK_LOCATION": "$GCP_REGION"
      }
    }
  }
}