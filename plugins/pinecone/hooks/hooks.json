{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pinecone-api-key-check.sh",
            "timeout": 15,
            "statusMessage": "Checking Pinecone authentication..."
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pinecone-api-key-check.sh",
            "timeout": 15,
            "statusMessage": "Checking Pinecone authentication..."
          }
        ]
      }
    ]
  }
}
