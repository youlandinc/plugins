{
  "version": 1,
  "hooks": {
    "sessionStart":       [{"command": "./scripts/cursor-on-event.sh"}],
    "sessionEnd":         [{"command": "./scripts/cursor-on-event.sh"}],
    "beforeSubmitPrompt": [{"command": "./scripts/cursor-on-event.sh"}],
    "afterAgentResponse": [{"command": "./scripts/cursor-on-event.sh"}],
