{
  "description": "Auto-refresh expired Spotify OAuth tokens before API calls (Gemini CLI; Claude Code and Codex use hooks/claude-hooks.json)",
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "type": "command",
            "name": "spotify-ads-token-refresh",
            "command": "bash \"${extensionPath}${/}hooks${/}check-token.sh\"",
            "timeout": 30000
          }
        ]
      }
    ]
  }
}
