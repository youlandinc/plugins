# Nimble Web Data Toolkit - Configuration
#
# Set environment variables using your platform's method:
#
# Claude Code:
#   Add to ~/.claude/settings.json:
#   {"env": {"NIMBLE_API_KEY": "your-key"}}
#
# VS Code / Cursor:
#   Use repository settings or shell environment
#
# Shell/Terminal:
#   export NIMBLE_API_KEY="your-key"
#
# .env file (this file):
#   Uncomment and set below (requires dotenv support)

# Required: Your Nimble API Key
# Get your key at: https://online.nimbleway.com/signup
NIMBLE_API_KEY=your-api-key-here


# Optional: Local MCP server URL for development
# NIMBLE_MCP_LOCAL_URL=http://localhost:9000/mcp