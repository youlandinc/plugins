{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "IdentityServer": {
    "IssuerUri": "https://identity.example.com"
  },
  "ReverseProxy": {
    "ProxyAddress": "10.0.0.1"
  },
  "ClientSecrets": {
    "WebApp": "super-secret-value-from-config",
    "InternalService": "internal-service-secret-value"
  }
}
