#!/usr/bin/env bash
# Runs skill e2e tests when staged changes touch skills/ or tests/e2e/.
# If the LLM judge passes, the refreshed hash cache is staged into the commit
# so CI sees a matching hash and skips re-evaluating the skill.
#
# Install via: task setup
# Bypass for a single commit: git commit --no-verify

set -euo pipefail

staged_paths=$(git diff --cached --name-only --diff-filter=ACMR)
if ! grep -qE '^(skills/|tests/e2e/)' <<<"$staged_paths"; then
    exit 0
fi

# Load .env so DATAROBOT_* creds are picked up the same way pytest does.
if [[ -f .env ]]; then
    set -a
    # shellcheck disable=SC1091
    source .env
    set +a
fi

if [[ -z "${DATAROBOT_API_TOKEN:-}" || -z "${DATAROBOT_ENDPOINT:-}" ]]; then
    cat >&2 <<'EOF'
pre-commit: skipping skill e2e tests (DATAROBOT_ENDPOINT / DATAROBOT_API_TOKEN not set).
            CI will run them as a safety net. To run locally:
              cp .env.example .env  # fill in the values
              git commit ...        # this hook will then evaluate changed skills
EOF
    exit 0
fi

echo "pre-commit: running skill e2e tests on staged changes..."
uv run --group e2e pytest tests/e2e/ -q --tb=short

if ! git diff --quiet -- tests/e2e/skill_hashes.json; then
    echo "pre-commit: staging refreshed tests/e2e/skill_hashes.json"
    git add tests/e2e/skill_hashes.json
fi
