    "darkCyan": "#909BF5",
    "darkAccent": "#909BF5",
    "darkBlue": "#87ADF8",
    "darkGreen": "#2BC46F",
    "darkGreenBright": "#56DF8A",
    "darkRed": "#ED7171",
    "darkRedBright": "#F79797",
    "darkYellow": "#E5D74C",
    "darkOrange": "#E98C3B",
    "darkTurquoise": "#61BFC5",
    "darkPurple": "#909BF5",
    "darkTeal": "#61BFC5",
    "darkSyntaxYellow": "#CEB31C",
    "darkSyntaxOrange": "#EDA769",
    "darkSyntaxGreen": "#56DF8A",
    "darkSyntaxBlue": "#42C0FC",
    "lightBg": "#FFFFFF",
