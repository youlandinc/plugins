  "theme": {
    "primary": {
      "dark": "darkCyan",
      "light": "lightTeal"
    },
    "secondary": {
      "dark": "darkCyan",
      "light": "lightBlue"
    },
    "accent": {
      "dark": "darkAccent",
      "light": "lightTeal"
    },
    "error": {
      "dark": "darkRed",
      "light": "lightRed"
    },
    "warning": {
      "dark": "darkYellow",
      "light": "lightOrange"
    },
    "success": {
      "dark": "darkGreen",
      "light": "lightGreen"
