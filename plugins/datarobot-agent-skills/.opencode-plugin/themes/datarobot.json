    "diffAddedBg": {
      "dark": "#3fa26633",
      "light": "#1f8a651f"
    },
    "diffRemovedBg": {
      "dark": "#b8004933",
      "light": "#cf2d5614"
    },
    "diffContextBg": {
      "dark": "darkPanel",
      "light": "lightPanel"
    },
    "diffLineNumber": {
      "dark": "#eeeeee87",
      "light": "textMuted"
