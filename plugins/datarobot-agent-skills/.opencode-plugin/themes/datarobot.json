    "markdownHeading": {
      "dark": "darkPurple",
      "light": "lightBlueDark"
    },
    "markdownLink": {
      "dark": "darkTeal",
      "light": "lightBlueDark"
    },
    "markdownLinkText": {
      "dark": "darkBlue",
      "light": "lightMuted"
    },
    "markdownCode": {
      "dark": "darkTurquoise",
      "light": "lightGreen"
    },
    "markdownBlockQuote": {
      "dark": "darkMuted",
      "light": "lightMuted"
    },
    "markdownEmph": {
      "dark": "darkTeal",
      "light": "lightFg"
    },
    "markdownStrong": {
      "dark": "darkSyntaxYellow",
      "light": "lightFg"
    },
    "markdownHorizontalRule": {
      "dark": "darkMuted",
      "light": "lightMuted"
    },
    "markdownListItem": {
      "dark": "darkFg",
      "light": "lightFg"
    },
    "markdownListEnumeration": {
      "dark": "darkCyan",
      "light": "lightMuted"
